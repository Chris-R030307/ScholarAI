# ScholarAI — environment variable names only (no secrets).
# Copy to web/.env.local and fill values there; never commit real keys.

# Semantic Scholar Graph API — optional; improves rate limits when set.
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# DeepSeek — ranking / reasoning (server-side only; Phase 3+).
DEEPSEEK_API_KEY=

# Google Gemini — synthesis / long context (server-side only; Phase 3+).
GEMINI_API_KEY=

# Optional: public site URL for production callbacks or metadata.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
