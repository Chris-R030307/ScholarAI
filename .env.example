# ScholarAI — environment variable names only (no secrets).
# Copy to web/.env.local and fill values there; never commit real keys.

# Semantic Scholar Graph API — optional; improves rate limits when set.
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# DeepSeek — ranking / reasoning (server-side only; Phase 3+).
DEEPSEEK_API_KEY=

# Google Gemini — synthesis / long context (server-side only; Phase 3+).
GEMINI_API_KEY=

# Optional: public site URL for production callbacks or metadata.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional friends-only gate (set BOTH to enable). Omit either → site is open as before.
# Friends visit /access (or get redirected), enter SCHOLARAI_ACCESS_CODE; server sets an httpOnly cookie (30d).
# ACCESS_GATE_SECRET must be a long random string (e.g. openssl rand -hex 32) — NOT the same as the access code.
# SCHOLARAI_ACCESS_CODE=
# ACCESS_GATE_SECRET=

# Administrator: set to true / 1 / yes / on to disable ALL LLM routes (AI search, chat, analyze).
# Semantic Scholar search still works. Omit or set false to allow LLM when keys exist.
# SCHOLARAI_LLM_DISABLED=false
